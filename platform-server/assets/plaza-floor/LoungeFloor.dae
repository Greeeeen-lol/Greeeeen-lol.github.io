<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset />
  <library_images>
    <image id="Floor_Alb">
      <init_from>Floor_Alb.png</init_from>
    </image>
    <image id="Floor_Nom">
      <init_from>Floor_Nom.png</init_from>
    </image>
    <image id="Floor_Emm">
      <init_from>Floor_Emm.png</init_from>
    </image>
    <image id="Floor_Spm">
      <init_from>Floor_Spm.png</init_from>
    </image>
  </library_images>
  <library_materials>
    <material id="m_floor">
      <instance_effect url="#Effect_m_floor" />
    </material>
  </library_materials>
  <library_effects>
    <effect id="Effect_m_floor">
      <profile_COMMON>
        <newparam sid="surface_m_floor-diffuse">
          <surface type="2D">
            <init_from>Floor_Alb</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="sampler_m_floor-diffuse">
          <sampler2D>
            <source>surface_m_floor-diffuse</source>
            <wrap_s>MIRROR</wrap_s>
            <wrap_t>MIRROR</wrap_t>
          </sampler2D>
        </newparam>
        <newparam sid="surface_m_floor-bump">
          <surface type="2D">
            <init_from>Floor_Nom</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="sampler_m_floor-bump">
          <sampler2D>
            <source>surface_m_floor-bump</source>
            <wrap_s>WRAP</wrap_s>
            <wrap_t>WRAP</wrap_t>
          </sampler2D>
        </newparam>
        <newparam sid="surface_m_floor-emission">
          <surface type="2D">
            <init_from>Floor_Emm</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="sampler_m_floor-emission">
          <sampler2D>
            <source>surface_m_floor-emission</source>
            <wrap_s>MIRROR</wrap_s>
            <wrap_t>MIRROR</wrap_t>
          </sampler2D>
        </newparam>
        <newparam sid="surface_m_floor-specular">
          <surface type="2D">
            <init_from>Floor_Spm</init_from>
            <format>A8R8G8B8</format>
          </surface>
        </newparam>
        <newparam sid="sampler_m_floor-specular">
          <sampler2D>
            <source>surface_m_floor-specular</source>
            <wrap_s>MIRROR</wrap_s>
            <wrap_t>MIRROR</wrap_t>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <phong>
            <diffuse>
              <texture texture="sampler_m_floor-diffuse" texcoord="CHANNEL0" />
            </diffuse>
            <bump>
              <texture texture="sampler_m_floor-bump" texcoord="CHANNEL0" />
            </bump>
            <emission>
              <texture texture="sampler_m_floor-emission" texcoord="CHANNEL0" />
            </emission>
            <specular>
              <texture texture="sampler_m_floor-specular" texcoord="CHANNEL0" />
            </specular>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>
  <library_geometries>
    <geometry id="floor__m_floor-mesh" name="floor__m_floor">
      <mesh>
        <source id="floor__m_floor-position">
